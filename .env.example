RACKPATCH_HTTP_PORT=3011
RACKPATCH_API_PORT=9080
RACKPATCH_NOTIFY_PORT=9091
RACKPATCH_VERSION=0.3.7
RACKPATCH_IMAGE_NAMESPACE=ghcr.io/schmidtcode
RACKPATCH_DB_PASSWORD=change-me
RACKPATCH_ADMIN_USERNAME=admin
RACKPATCH_ADMIN_PASSWORD=change-me
RACKPATCH_AUTH_SECRET=change-me
RACKPATCH_AGENT_BOOTSTRAP_TOKEN=bootstrap-me
RACKPATCH_SITE_NAME=example
RACKPATCH_SITE_ROOT=/opt/rackpatch/sites/example
RACKPATCH_PUBLIC_BASE_URL=http://YOUR-RACKPATCH-HOST:3011
RACKPATCH_PUBLIC_REPO_URL=https://github.com/SchmidtCode/rackpatch.git
RACKPATCH_PUBLIC_REPO_REF=main
RACKPATCH_PUBLIC_INSTALL_SCRIPT_URL=
RACKPATCH_PUBLIC_AGENT_COMPOSE_DIR=/srv/compose/rackpatch-agent
RACKPATCH_PUBLIC_RACKPATCH_COMPOSE_DIR=/srv/compose/rackpatch
RACKPATCH_SELF_AGENT_BOOTSTRAP_TOKEN=
RACKPATCH_SELF_AGENT_NAME=
RACKPATCH_SELF_AGENT_DISPLAY_NAME=
RACKPATCH_SELF_AGENT_LABELS=control-plane,self-agent
RACKPATCH_SELF_AGENT_HELPER_SOCKET=/run/rackpatch-host-helper/rackpatch-host-helper.sock
RACKPATCH_CORS_ORIGINS=
RACKPATCH_COMPOSE_ROOT=/srv/compose
RACKPATCH_DB_VOLUME=rackpatch-db-data
RACKPATCH_DB_VOLUME_EXTERNAL=false
TZ=America/New_York
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
