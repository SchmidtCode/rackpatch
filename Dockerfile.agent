FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        docker.io \
        docker-compose \
        jq \
        sudo \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-ops.txt /tmp/requirements-ops.txt

RUN pip install --no-cache-dir -r /tmp/requirements-ops.txt

WORKDIR /opt/ops-agent

COPY app /opt/ops-app

ENV PYTHONPATH=/opt/ops-app \
    PYTHONUNBUFFERED=1

CMD ["python3", "-m", "agent.main"]

